{
  "schema_version": "1.0.0", "id": "BACKEND-IDEMPOTENCY-RETRIES", "kind": "BACKEND_PATTERN", "domain": "IDEMPOTENCY_AND_RETRIES", "name": "Idempotencia y reintentos", "purpose": "Hacer que operaciones repetidas converjan al mismo efecto y que los reintentos sean acotados y observables.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["operation_retry_classes", "user_visible_timeout_policy"], "environment_managed": ["idempotency_store_reference", "clock_reference", "retry_budget"], "validation_rules": ["Presupuesto tiene límite positivo", "Solo fallos clasificados como temporales se reintentan", "TTL supera la ventana máxima de duplicados"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Store se identifica por referencia", "Claves se derivan de identificadores opacos", "Payload sensible no forma parte de logs de reintento"]},
  "interfaces": {"inputs": [{"name": "idempotency_key", "type": "opaque_string", "required": true, "classification": "SENSITIVE_REFERENCE"}, {"name": "operation_fingerprint", "type": "digest", "required": true, "classification": "INTERNAL"}], "outputs": [{"name": "stable_result", "type": "object", "classification": "INTERNAL"}, {"name": "attempt_disposition", "type": "enum", "classification": "INTERNAL"}]},
  "invariants": ["Misma clave y mismo fingerprint producen mismo resultado", "Misma clave y distinto fingerprint se rechazan", "Una operación tiene un único propietario de ejecución", "Reintentos tienen backoff, jitter y presupuesto", "Resultado terminal se conserva durante TTL"],
  "state_machine": [{"from": "ABSENT", "event": "CLAIMED", "to": "IN_PROGRESS", "guard": "creación atómica"}, {"from": "IN_PROGRESS", "event": "SUCCEEDED", "to": "COMPLETED", "guard": "resultado persistido atómicamente"}, {"from": "IN_PROGRESS", "event": "TEMPORARY_FAILURE", "to": "RETRY_SCHEDULED", "guard": "presupuesto disponible"}, {"from": "RETRY_SCHEDULED", "event": "BUDGET_EXHAUSTED", "to": "FAILED_TERMINAL", "guard": "límite alcanzado"}],
  "failure_modes": [{"code": "IDEMPOTENCY_CONFLICT", "condition": "Clave reutilizada con fingerprint distinto", "response": "Rechazar sin ejecutar", "retryable": false}, {"code": "RETRY_BUDGET_EXHAUSTED", "condition": "Intentos agotados", "response": "Estado terminal y alerta", "retryable": false}, {"code": "EXECUTION_LEASE_LOST", "condition": "Propiedad de ejecución expira", "response": "Consultar resultado antes de reclamar", "retryable": true}],
  "idempotency": {"required": true, "key_scope": "tenant + operation_type + business_reference", "duplicate_behavior": "Devuelve estado o resultado estable sin repetir efecto"},
  "audit": {"events": ["OPERATION_CLAIMED", "RETRY_SCHEDULED", "OPERATION_COMPLETED", "RETRY_EXHAUSTED"], "required_fields": ["operation_id", "idempotency_key_hash", "attempt", "occurred_at", "disposition"], "redacted_fields": ["idempotency_key", "request_payload", "secret_reference"]},
  "security": {"trust_boundary": "Claves del cliente se validan y se acotan por tenant", "authorization_rule": "Solo principal autorizado puede consultar resultado", "data_minimization": "Store conserva fingerprint, estado y resultado mínimo", "threat_controls": ["Ámbito por tenant", "Creación atómica", "TTL acotado", "Jitter contra tormentas"]},
  "test_contract": [{"id": "IDEM-T01", "given": "Misma clave y payload", "when": "Se repite", "then": "Efecto ocurre una vez"}, {"id": "IDEM-T02", "given": "Misma clave y otro payload", "when": "Se repite", "then": "Se rechaza conflicto"}, {"id": "IDEM-T03", "given": "Fallo temporal", "when": "Se reintenta", "then": "Respeta presupuesto y backoff"}, {"id": "IDEM-T04", "given": "Dos workers", "when": "Reclaman simultáneamente", "then": "Solo uno ejecuta"}, {"id": "IDEM-T05", "given": "Resultado terminal", "when": "Llega duplicado", "then": "Devuelve resultado estable"}],
  "forbidden": ["Reintentos infinitos", "Clave global sin tenant", "Reutilizar clave con payload distinto", "Reintentar fallos permanentes", "Ejecutar antes de reclamar atómicamente"]
}
