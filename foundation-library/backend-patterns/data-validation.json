{
  "schema_version": "1.0.0", "id": "BACKEND-DATA-VALIDATION", "kind": "BACKEND_PATTERN", "domain": "DATA_VALIDATION", "name": "Validación de datos", "purpose": "Transformar entradas no confiables en comandos tipados, normalizados y limitados antes de ejecutar lógica.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["locale", "business_field_catalog", "allowed_value_catalog"], "environment_managed": ["schema_version_policy", "payload_size_limit", "malware_scanner_reference"], "validation_rules": ["Catálogos tienen versión", "Límites son positivos", "Locale no cambia representación canónica"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Escáner externo se referencia sin credencial", "Errores no reproducen valores sensibles", "Muestras reales no viven en documentación"]},
  "interfaces": {"inputs": [{"name": "untrusted_payload", "type": "unknown", "required": true, "classification": "PERSONAL"}, {"name": "schema_version", "type": "string", "required": true, "classification": "PUBLIC"}], "outputs": [{"name": "validated_command", "type": "typed_object", "classification": "INTERNAL"}, {"name": "validation_errors", "type": "field_error_list", "classification": "PERSONAL"}]},
  "invariants": ["Toda frontera valida antes de usar", "Campos desconocidos se rechazan o eliminan explícitamente", "Normalización precede reglas de negocio", "Errores usan códigos estables", "Tamaño y profundidad están limitados"],
  "state_machine": [{"from": "UNTRUSTED", "event": "STRUCTURE_VALID", "to": "STRUCTURED", "guard": "schema y límites satisfechos"}, {"from": "STRUCTURED", "event": "NORMALIZED", "to": "CANONICAL", "guard": "transformaciones deterministas"}, {"from": "CANONICAL", "event": "BUSINESS_RULES_PASSED", "to": "VALIDATED", "guard": "catálogos y permisos vigentes"}],
  "failure_modes": [{"code": "VALIDATION_SHAPE_INVALID", "condition": "Estructura no cumple schema", "response": "Rechazar con códigos de campo", "retryable": false}, {"code": "VALIDATION_LIMIT_EXCEEDED", "condition": "Tamaño o profundidad excedidos", "response": "Rechazar antes de parseo costoso", "retryable": false}, {"code": "VALIDATION_CATALOG_STALE", "condition": "Versión de catálogo obsoleta", "response": "Solicitar actualización controlada", "retryable": true}],
  "idempotency": {"required": false, "key_scope": "La validación pura usa digest de payload y schema", "duplicate_behavior": "Misma entrada produce mismo resultado"},
  "audit": {"events": ["VALIDATION_REJECTED", "VALIDATION_POLICY_MISMATCH"], "required_fields": ["event_id", "occurred_at", "schema_version", "error_codes", "request_reference"], "redacted_fields": ["field_values", "raw_payload", "uploaded_content"]},
  "security": {"trust_boundary": "Toda entrada externa inicia como no confiable", "authorization_rule": "Validación estructural no concede permiso", "data_minimization": "Se descartan campos no necesarios", "threat_controls": ["Límites de tamaño y profundidad", "Allowlist de tipos", "Normalización Unicode", "Rechazo de campos ambiguos"]},
  "test_contract": [{"id": "VAL-T01", "given": "Payload válido", "when": "Se valida", "then": "Produce comando canónico"}, {"id": "VAL-T02", "given": "Campo desconocido", "when": "Se valida", "then": "Se aplica política explícita"}, {"id": "VAL-T03", "given": "Payload excesivo", "when": "Llega", "then": "Se rechaza temprano"}, {"id": "VAL-T04", "given": "Unicode ambiguo", "when": "Se normaliza", "then": "Resultado es determinista"}, {"id": "VAL-T05", "given": "Valor sensible inválido", "when": "Se informa error", "then": "Valor no se refleja"}],
  "forbidden": ["Confiar en tipos del cliente", "Reflejar payload en errores", "Coerción silenciosa ambigua", "Campos ilimitados", "Usar validación como autorización"]
