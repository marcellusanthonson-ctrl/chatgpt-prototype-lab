{
  "schema_version": "1.0.0", "id": "BACKEND-PROVIDER-CONFIGURATION", "kind": "BACKEND_PATTERN", "domain": "PROVIDER_CONFIGURATION", "name": "Configuración de proveedor", "purpose": "Permitir sustituir configuración de cliente sin mezclar secretos, entornos, cuentas o capacidades de proveedores.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["client_id", "display_name", "locale", "currency_policy", "feature_policy", "public_brand_tokens", "business_routes"], "environment_managed": ["provider_account_reference", "credential_reference", "endpoint_profile", "webhook_reference", "secret_version_reference"], "validation_rules": ["Client ID es estable y no secreto", "Toda referencia incluye ambiente", "Capacidades solicitadas existen en perfil", "Rutas pertenecen a orígenes permitidos"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Configuración documental contiene referencias, nunca valores secretos", "Cada cliente y ambiente resuelve su propio namespace", "Rotación cambia versión de referencia sin cambiar contrato", "Valores resueltos nunca regresan al cliente"]},
  "interfaces": {"inputs": [{"name": "client_configuration", "type": "validated_object", "required": true, "classification": "PUBLIC"}, {"name": "environment", "type": "enum", "required": true, "classification": "INTERNAL"}, {"name": "capability_request", "type": "string", "required": true, "classification": "INTERNAL"}], "outputs": [{"name": "provider_profile", "type": "non_secret_object", "classification": "INTERNAL"}, {"name": "secret_reference_set", "type": "opaque_references", "classification": "SENSITIVE_REFERENCE"}]},
  "invariants": ["Cliente y ambiente forman namespace aislado", "Configuración pública no contiene material secreto", "Capacidades se verifican antes de uso", "Fallback nunca cruza cliente o ambiente", "Cambios tienen versión y auditoría"],
  "state_machine": [{"from": "DRAFT", "event": "SCHEMA_VALIDATED", "to": "VALIDATED", "guard": "campos y referencias permitidos"}, {"from": "VALIDATED", "event": "REFERENCES_RESOLVED", "to": "READY", "guard": "namespace coincide con cliente y ambiente"}, {"from": "READY", "event": "REFERENCE_ROTATED", "to": "READY", "guard": "nueva versión activa y anterior revocada"}, {"from": "READY", "event": "CAPABILITY_REMOVED", "to": "DEGRADED", "guard": "fallback seguro definido"}],
  "failure_modes": [{"code": "CONFIG_NAMESPACE_MISMATCH", "condition": "Referencia pertenece a otro cliente o ambiente", "response": "Fallar cerrado y alertar", "retryable": false}, {"code": "CONFIG_CAPABILITY_MISSING", "condition": "Proveedor no soporta capacidad", "response": "Usar degradación explícita o rechazar", "retryable": false}, {"code": "CONFIG_REFERENCE_UNAVAILABLE", "condition": "Gestor temporalmente inaccesible", "response": "Fallar cerrado; no usar valor de otro scope", "retryable": true}],
  "idempotency": {"required": true, "key_scope": "client_id + environment + configuration_version", "duplicate_behavior": "Misma versión produce mismo perfil no secreto"},
  "audit": {"events": ["CONFIG_VALIDATED", "CONFIG_ACTIVATED", "REFERENCE_ROTATED", "CONFIG_REJECTED"], "required_fields": ["event_id", "occurred_at", "client_id", "environment", "configuration_version", "outcome"], "redacted_fields": ["resolved_secret", "credential", "webhook_secret", "provider_token"]},
  "security": {"trust_boundary": "Configuración de cliente es entrada no confiable hasta validar", "authorization_rule": "Activación y rotación requieren rol administrativo", "data_minimization": "Perfil expone solo capacidades y referencias necesarias", "threat_controls": ["Namespace por cliente y ambiente", "Allowlist de campos", "Referencias opacas", "Fallo cerrado", "Auditoría de versiones"]},
  "test_contract": [{"id": "CFG-T01", "given": "Configuración válida", "when": "Se activa", "then": "Produce perfil sin secretos"}, {"id": "CFG-T02", "given": "Referencia de otro cliente", "when": "Se resuelve", "then": "Se rechaza"}, {"id": "CFG-T03", "given": "Campo secreto en payload", "when": "Se valida", "then": "Se rechaza"}, {"id": "CFG-T04", "given": "Rotación válida", "when": "Se activa", "then": "Nueva versión se usa y anterior se revoca"}, {"id": "CFG-T05", "given": "Capacidad ausente", "when": "Se solicita", "then": "Degradación es explícita o falla"}],
  "forbidden": ["Incluir valores secretos en JSON", "Compartir referencias entre clientes", "Fallback a otro ambiente", "Confiar en capacidades no declaradas", "Exponer valores resueltos al navegador", "Editar configuración sin versión"]
}
