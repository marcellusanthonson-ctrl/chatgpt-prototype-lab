{
  "schema_version": "1.0.0", "id": "BACKEND-AUTHENTICATION-AUTHORIZATION", "kind": "BACKEND_PATTERN", "domain": "AUTHENTICATION_AND_AUTHORIZATION", "name": "Autenticación y autorización", "purpose": "Separar prueba de identidad, sesión y decisión de permisos mediante denegación por defecto.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["tenant_display_name", "allowed_login_methods", "session_duration_policy", "role_catalog"], "environment_managed": ["identity_provider_reference", "signing_key_reference", "callback_origin_allowlist"], "validation_rules": ["Roles usan identificadores estables", "Orígenes son HTTPS y pertenecen al entorno", "Duración respeta límites organizacionales"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Llaves y tokens viven en un gestor de secretos", "El repositorio contiene solo nombres de referencia", "Ningún log contiene tokens, cookies o códigos"]},
  "interfaces": {"inputs": [{"name": "identity_assertion_reference", "type": "opaque_reference", "required": true, "classification": "SENSITIVE_REFERENCE"}, {"name": "requested_action", "type": "string", "required": true, "classification": "INTERNAL"}, {"name": "resource_context", "type": "object", "required": true, "classification": "INTERNAL"}], "outputs": [{"name": "principal", "type": "object", "classification": "PERSONAL"}, {"name": "authorization_decision", "type": "allow_or_deny", "classification": "INTERNAL"}]},
  "invariants": ["Autenticación no implica autorización", "Toda acción protegida se evalúa en servidor", "Ausencia de política produce denegación", "Sesiones pueden revocarse", "Privilegios siguen mínima autoridad"],
  "state_machine": [{"from": "ANONYMOUS", "event": "IDENTITY_VERIFIED", "to": "AUTHENTICATED", "guard": "assertion validada para audiencia y entorno"}, {"from": "AUTHENTICATED", "event": "SESSION_REVOKED", "to": "REVOKED", "guard": "evento autorizado o expiración"}, {"from": "AUTHENTICATED", "event": "SESSION_EXPIRED", "to": "EXPIRED", "guard": "reloj confiable supera vencimiento"}],
  "failure_modes": [{"code": "AUTH_INVALID_ASSERTION", "condition": "Afirmación inválida o vencida", "response": "Denegar sin revelar detalle", "retryable": false}, {"code": "AUTH_POLICY_DENIED", "condition": "Permiso insuficiente", "response": "Denegar y auditar decisión", "retryable": false}, {"code": "AUTH_PROVIDER_UNAVAILABLE", "condition": "Proveedor temporalmente inaccesible", "response": "Fallar cerrado y permitir reintento acotado", "retryable": true}],
  "idempotency": {"required": false, "key_scope": "No aplica a lectura de decisión; revocación usa session_id", "duplicate_behavior": "Revocación repetida conserva REVOKED"},
  "audit": {"events": ["AUTHENTICATION_SUCCEEDED", "AUTHENTICATION_FAILED", "AUTHORIZATION_DENIED", "SESSION_REVOKED"], "required_fields": ["event_id", "occurred_at", "principal_reference", "action", "outcome"], "redacted_fields": ["assertion", "token", "cookie", "authorization_header"]},
  "security": {"trust_boundary": "Toda evidencia externa se valida antes de crear principal", "authorization_rule": "Servidor decide permiso para cada recurso y acción", "data_minimization": "Principal contiene solo atributos necesarios", "threat_controls": ["Protección contra fijación de sesión", "Validación de issuer, audience y nonce", "Rotación y revocación", "Rate limiting por riesgo"]},
  "test_contract": [{"id": "AUTH-T01", "given": "Afirmación válida", "when": "Se solicita sesión", "then": "Se crea principal mínimo"}, {"id": "AUTH-T02", "given": "Audiencia incorrecta", "when": "Se valida", "then": "Se deniega"}, {"id": "AUTH-T03", "given": "Usuario autenticado sin permiso", "when": "Actúa", "then": "Se deniega y audita"}, {"id": "AUTH-T04", "given": "Sesión revocada", "when": "Se reutiliza", "then": "Se rechaza"}, {"id": "AUTH-T05", "given": "Proveedor caído", "when": "Se autentica", "then": "Falla cerrado sin filtrar secretos"}],
  "forbidden": ["Confiar en roles enviados por cliente", "Autorizar solo en interfaz", "Registrar tokens o cookies", "Compartir sesiones entre entornos", "Permitir por ausencia de política"]
}
