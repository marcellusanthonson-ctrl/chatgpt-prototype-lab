{
  "schema_version": "1.0.0", "id": "BACKEND-AUDIT-LOGGING", "kind": "BACKEND_PATTERN", "domain": "AUDIT_LOGGING", "name": "Registro de auditoría", "purpose": "Crear evidencia inmutable y mínima sobre quién hizo qué, cuándo, sobre qué recurso y con qué resultado.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["retention_class", "audited_business_events", "timezone_display_policy"], "environment_managed": ["audit_sink_reference", "integrity_key_reference", "clock_reference"], "validation_rules": ["Eventos usan catálogo versionado", "Retención pertenece a política aprobada", "Zona de almacenamiento permanece UTC"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Sink e integridad se resuelven por referencia", "Secretos nunca aparecen en eventos", "Acceso a auditoría está separado de operación"]},
  "interfaces": {"inputs": [{"name": "audit_event", "type": "structured_event", "required": true, "classification": "INTERNAL"}, {"name": "actor_reference", "type": "opaque_id", "required": true, "classification": "PERSONAL"}], "outputs": [{"name": "audit_event_id", "type": "opaque_id", "classification": "INTERNAL"}, {"name": "integrity_receipt", "type": "digest", "classification": "INTERNAL"}]},
  "invariants": ["Eventos son append-only", "Tiempo se registra en UTC", "Actor, acción, recurso y resultado son obligatorios", "Datos sensibles se redactan antes de persistir", "Acceso y exportación también se auditan"],
  "state_machine": [{"from": "PROPOSED", "event": "REDACTION_PASSED", "to": "SANITIZED", "guard": "clasificación completa"}, {"from": "SANITIZED", "event": "APPENDED", "to": "RECORDED", "guard": "identificador e integridad emitidos"}, {"from": "RECORDED", "event": "RETENTION_EXPIRED", "to": "DISPOSED", "guard": "política autorizada y evidencia de disposición"}],
  "failure_modes": [{"code": "AUDIT_SCHEMA_INVALID", "condition": "Falta campo obligatorio", "response": "Rechazar evento y alertar operación", "retryable": false}, {"code": "AUDIT_SINK_UNAVAILABLE", "condition": "Sink temporalmente inaccesible", "response": "Buffer duradero acotado o fallar cerrado según criticidad", "retryable": true}, {"code": "AUDIT_SENSITIVE_DATA", "condition": "Campo prohibido detectado", "response": "Redactar o rechazar antes de almacenar", "retryable": false}],
  "idempotency": {"required": true, "key_scope": "source_event_id + audit_event_type", "duplicate_behavior": "Conserva un evento y devuelve el receipt existente"},
  "audit": {"events": ["AUDIT_EVENT_RECORDED", "AUDIT_EVENT_REJECTED", "AUDIT_LOG_ACCESSED", "AUDIT_EXPORT_CREATED"], "required_fields": ["event_id", "occurred_at", "actor_reference", "action", "resource_reference", "outcome"], "redacted_fields": ["secret", "token", "password", "raw_personal_payload"]},
  "security": {"trust_boundary": "Evento se considera no confiable hasta clasificar y redactar", "authorization_rule": "Lectura y exportación requieren permiso separado", "data_minimization": "Solo evidencia necesaria para trazabilidad", "threat_controls": ["Append-only", "Integridad verificable", "Control de acceso separado", "Alertas de huecos de secuencia"]},
  "test_contract": [{"id": "AUD-T01", "given": "Evento válido", "when": "Se registra", "then": "Obtiene ID y receipt"}, {"id": "AUD-T02", "given": "Evento duplicado", "when": "Se repite", "then": "No duplica evidencia"}, {"id": "AUD-T03", "given": "Campo secreto", "when": "Se clasifica", "then": "No se persiste"}, {"id": "AUD-T04", "given": "Usuario sin permiso", "when": "Consulta", "then": "Se deniega y audita"}, {"id": "AUD-T05", "given": "Retención vencida", "when": "Se dispone", "then": "Queda evidencia de política aplicada"}],
  "forbidden": ["Modificar eventos existentes", "Guardar secretos o payloads completos", "Usar hora local como fuente", "Permitir acceso operativo implícito", "Eliminar sin política y evidencia"]
}
