{
  "schema_version": "1.0.0", "id": "BACKEND-WEBHOOK-PROCESSING", "kind": "BACKEND_PATTERN", "domain": "WEBHOOK_PROCESSING", "name": "Procesamiento de webhooks", "purpose": "Aceptar eventos externos con autenticidad, deduplicación, orden tolerante y procesamiento recuperable.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["enabled_event_types", "business_routing_rules", "retention_class"], "environment_managed": ["webhook_secret_reference", "endpoint_identity", "provider_clock_tolerance"], "validation_rules": ["Tipos habilitados pertenecen al catálogo", "Tolerancia temporal tiene límite", "Reglas no contienen secretos"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Secretos se resuelven por referencia en ejecución", "Payload crudo tiene acceso restringido", "Cabeceras de autenticación se redactan"]},
  "interfaces": {"inputs": [{"name": "raw_body", "type": "bytes", "required": true, "classification": "SENSITIVE_REFERENCE"}, {"name": "signature_headers", "type": "map", "required": true, "classification": "SENSITIVE_REFERENCE"}, {"name": "received_at", "type": "timestamp", "required": true, "classification": "INTERNAL"}], "outputs": [{"name": "receipt_reference", "type": "opaque_id", "classification": "INTERNAL"}, {"name": "processing_disposition", "type": "enum", "classification": "INTERNAL"}]},
  "invariants": ["Firma se verifica sobre bytes originales", "Evento se persiste antes de confirmar recepción", "Event ID se procesa una vez", "Orden de llegada no se asume como orden causal", "Respuesta rápida no depende del efecto de negocio"],
  "state_machine": [{"from": "RECEIVED", "event": "SIGNATURE_VERIFIED", "to": "VERIFIED", "guard": "firma, tiempo y endpoint válidos"}, {"from": "VERIFIED", "event": "RECEIPT_PERSISTED", "to": "QUEUED", "guard": "event_id único"}, {"from": "QUEUED", "event": "HANDLER_SUCCEEDED", "to": "PROCESSED", "guard": "efecto idempotente confirmado"}, {"from": "QUEUED", "event": "RETRY_EXHAUSTED", "to": "QUARANTINED", "guard": "política de reintento agotada"}],
  "failure_modes": [{"code": "WEBHOOK_BAD_SIGNATURE", "condition": "Autenticidad inválida", "response": "Rechazar y registrar metadatos mínimos", "retryable": false}, {"code": "WEBHOOK_DUPLICATE", "condition": "Event ID ya recibido", "response": "Confirmar sin repetir efecto", "retryable": false}, {"code": "WEBHOOK_HANDLER_FAILED", "condition": "Efecto temporalmente falla", "response": "Reintentar con backoff y límite", "retryable": true}],
  "idempotency": {"required": true, "key_scope": "provider_environment + endpoint_identity + event_id", "duplicate_behavior": "Confirma recepción y devuelve disposición previa"},
  "audit": {"events": ["WEBHOOK_RECEIVED", "WEBHOOK_REJECTED", "WEBHOOK_PROCESSED", "WEBHOOK_QUARANTINED"], "required_fields": ["event_id", "received_at", "provider_reference", "event_type", "disposition"], "redacted_fields": ["raw_body", "signature", "authorization_header"]},
  "security": {"trust_boundary": "Todo evento entrante es no confiable hasta verificar bytes y firma", "authorization_rule": "Solo tipos permitidos alcanzan handlers", "data_minimization": "Auditoría conserva hash y metadatos, no payload indiscriminado", "threat_controls": ["Verificación criptográfica", "Ventana contra replay", "Límite de tamaño", "Deduplicación atómica"]},
  "test_contract": [{"id": "WH-T01", "given": "Firma válida", "when": "Se recibe", "then": "Se persiste antes de confirmar"}, {"id": "WH-T02", "given": "Firma inválida", "when": "Se recibe", "then": "No se ejecuta handler"}, {"id": "WH-T03", "given": "Evento duplicado", "when": "Se recibe", "then": "No repite efecto"}, {"id": "WH-T04", "given": "Eventos fuera de orden", "when": "Se procesan", "then": "Guardas preservan estado válido"}, {"id": "WH-T05", "given": "Handler temporalmente falla", "when": "Se reintenta", "then": "Usa backoff y termina o pone en cuarentena"}],
  "forbidden": ["Parsear antes de verificar cuando altera bytes", "Responder éxito antes de persistir", "Asumir orden de entrega", "Registrar payload completo por defecto", "Repetir efectos no idempotentes"]
}
