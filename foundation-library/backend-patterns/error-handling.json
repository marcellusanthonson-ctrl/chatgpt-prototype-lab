{
  "schema_version": "1.0.0", "id": "BACKEND-ERROR-HANDLING", "kind": "BACKEND_PATTERN", "domain": "ERROR_HANDLING", "name": "Manejo de errores", "purpose": "Clasificar fallos, entregar respuestas seguras y correlacionables, y preservar información diagnóstica sin filtrarla.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["support_contact", "localized_message_catalog", "user_recovery_routes"], "environment_managed": ["error_sink_reference", "trace_sampling_policy", "incident_channel_reference"], "validation_rules": ["Mensajes se mapean desde códigos estables", "Rutas de recuperación pertenecen a allowlist", "Contacto no contiene secretos"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Stack traces solo en observabilidad restringida", "Respuesta pública nunca incluye secretos", "Referencias de incidentes no exponen canales internos"]},
  "interfaces": {"inputs": [{"name": "caught_failure", "type": "unknown", "required": true, "classification": "SENSITIVE_REFERENCE"}, {"name": "request_context", "type": "sanitized_object", "required": true, "classification": "INTERNAL"}], "outputs": [{"name": "public_error", "type": "coded_problem", "classification": "PUBLIC"}, {"name": "correlation_id", "type": "opaque_id", "classification": "PUBLIC"}, {"name": "internal_diagnostic", "type": "structured_event", "classification": "INTERNAL"}]},
  "invariants": ["Errores públicos usan códigos estables", "Detalle interno y mensaje público están separados", "Cada fallo inesperado tiene correlación", "Clasificación determina reintento y severidad", "Errores no cambian exitosamente estado parcial sin compensación"],
  "state_machine": [{"from": "CAUGHT", "event": "CLASSIFIED", "to": "SANITIZED", "guard": "tipo, severidad y retryability definidos"}, {"from": "SANITIZED", "event": "DIAGNOSTIC_RECORDED", "to": "REPORTED", "guard": "correlation_id emitido"}, {"from": "REPORTED", "event": "INCIDENT_THRESHOLD_REACHED", "to": "ESCALATED", "guard": "política de alerta satisfecha"}],
  "failure_modes": [{"code": "ERROR_EXPECTED", "condition": "Regla conocida impide acción", "response": "Código específico y recuperación", "retryable": false}, {"code": "ERROR_TEMPORARY_DEPENDENCY", "condition": "Dependencia transitoria", "response": "Código temporal y reintento acotado", "retryable": true}, {"code": "ERROR_UNEXPECTED", "condition": "Fallo no clasificado", "response": "Mensaje genérico, correlación y alerta", "retryable": false}],
  "idempotency": {"required": false, "key_scope": "correlation_id + failure_fingerprint", "duplicate_behavior": "Agrupa diagnósticos sin ocultar conteo"},
  "audit": {"events": ["ERROR_CLASSIFIED", "ERROR_REPORTED", "ERROR_ESCALATED"], "required_fields": ["correlation_id", "occurred_at", "error_code", "severity", "operation", "retryable"], "redacted_fields": ["stack_trace_public", "secret", "request_body", "personal_data"]},
  "security": {"trust_boundary": "Excepciones y mensajes de dependencias son no confiables", "authorization_rule": "Diagnósticos internos requieren rol de operación", "data_minimization": "Respuesta pública contiene código, mensaje seguro y correlación", "threat_controls": ["Sanitización central", "Códigos allowlisted", "Redacción estructurada", "Agrupación y rate limiting"]},
  "test_contract": [{"id": "ERR-T01", "given": "Error esperado", "when": "Se maneja", "then": "Devuelve código y recuperación"}, {"id": "ERR-T02", "given": "Excepción con secreto", "when": "Se maneja", "then": "Secreto no aparece en respuesta ni evento"}, {"id": "ERR-T03", "given": "Fallo inesperado", "when": "Se maneja", "then": "Genera correlación"}, {"id": "ERR-T04", "given": "Dependencia temporal", "when": "Se clasifica", "then": "Retryability es verdadera y acotada"}, {"id": "ERR-T05", "given": "Muchos fallos iguales", "when": "Se observan", "then": "Se agrupan sin perder conteo"}],
  "forbidden": ["Exponer stack trace al usuario", "Devolver mensajes crudos de proveedor", "Capturar y continuar silenciosamente", "Marcar todo como reintentable", "Registrar request completo por defecto"]
}
