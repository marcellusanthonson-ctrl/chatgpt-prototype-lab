{
  "schema_version": "1.0.0", "id": "BACKEND-TRANSACTIONAL-STATE", "kind": "BACKEND_PATTERN", "domain": "TRANSACTIONAL_STATE", "name": "Estado transaccional", "purpose": "Definir transiciones válidas, concurrencia, efectos y compensaciones para procesos de negocio duraderos.", "provider_neutral": true,
  "configuration_contract": {"client_replaceable": ["business_state_labels", "allowed_cancellation_reasons", "timeout_policy"], "environment_managed": ["transaction_store_reference", "outbox_reference", "clock_reference"], "validation_rules": ["Etiquetas mapean a estados estables", "Timeouts son positivos", "Razones usan catálogo versionado"]},
  "secret_boundary": {"repository_values_allowed": false, "reference_only": true, "rules": ["Stores se resuelven por referencia", "Eventos no contienen secretos", "Snapshots personales se minimizan"]},
  "interfaces": {"inputs": [{"name": "aggregate_reference", "type": "opaque_id", "required": true, "classification": "INTERNAL"}, {"name": "command", "type": "validated_object", "required": true, "classification": "INTERNAL"}, {"name": "expected_version", "type": "integer", "required": true, "classification": "INTERNAL"}], "outputs": [{"name": "new_state", "type": "enum", "classification": "INTERNAL"}, {"name": "new_version", "type": "integer", "classification": "INTERNAL"}, {"name": "emitted_events", "type": "array", "classification": "INTERNAL"}]},
  "invariants": ["Solo transiciones declaradas son válidas", "Versión evita escritura perdida", "Estado y outbox se confirman atómicamente", "Efectos externos ocurren después del commit", "Compensación es explícita y auditable"],
  "state_machine": [{"from": "DRAFT", "event": "SUBMITTED", "to": "PENDING", "guard": "datos válidos y versión coincide"}, {"from": "PENDING", "event": "CONFIRMED", "to": "COMPLETED", "guard": "evidencia requerida presente"}, {"from": "PENDING", "event": "CANCELLED", "to": "CANCELLED", "guard": "motivo permitido y actor autorizado"}, {"from": "COMPLETED", "event": "COMPENSATION_APPROVED", "to": "COMPENSATED", "guard": "política y referencia original válidas"}],
  "failure_modes": [{"code": "STATE_INVALID_TRANSITION", "condition": "Evento no permitido desde estado", "response": "Rechazar sin mutar", "retryable": false}, {"code": "STATE_VERSION_CONFLICT", "condition": "Versión esperada difiere", "response": "Recargar y reevaluar comando", "retryable": true}, {"code": "STATE_EFFECT_PENDING", "condition": "Commit realizado y efecto externo pendiente", "response": "Reprocesar outbox idempotente", "retryable": true}],
  "idempotency": {"required": true, "key_scope": "aggregate_reference + command_id", "duplicate_behavior": "Devuelve versión y eventos del comando original"},
  "audit": {"events": ["STATE_TRANSITION_ACCEPTED", "STATE_TRANSITION_REJECTED", "STATE_COMPENSATED"], "required_fields": ["event_id", "occurred_at", "aggregate_reference", "from_state", "to_state", "actor_reference", "version"], "redacted_fields": ["command_payload", "personal_snapshot", "secret_reference"]},
  "security": {"trust_boundary": "Comandos se revalidan dentro de frontera transaccional", "authorization_rule": "Cada transición exige actor y política", "data_minimization": "Eventos contienen referencias y hechos mínimos", "threat_controls": ["Control de concurrencia optimista", "Outbox transaccional", "Idempotencia de comando", "Guardas por estado y actor"]},
  "test_contract": [{"id": "STATE-T01", "given": "Transición válida", "when": "Versión coincide", "then": "Estado y evento se confirman juntos"}, {"id": "STATE-T02", "given": "Transición inválida", "when": "Se solicita", "then": "No muta"}, {"id": "STATE-T03", "given": "Versión antigua", "when": "Se escribe", "then": "Conflicto explícito"}, {"id": "STATE-T04", "given": "Outbox falla", "when": "Se recupera", "then": "Efecto se reintenta sin repetir transición"}, {"id": "STATE-T05", "given": "Comando duplicado", "when": "Se repite", "then": "Devuelve resultado original"}],
  "forbidden": ["Mutar estado fuera de transición", "Publicar antes de commit", "Sobrescribir conflicto", "Compensar sin evidencia", "Ejecutar efecto externo dentro de transacción larga"]
}
