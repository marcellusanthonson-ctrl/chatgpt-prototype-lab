{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab.local/schemas/current-state.schema.json",
  "title": "current-state",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "version",
    "status",
    "updated_at",
    "active_project",
    "current_phase",
    "methodology",
    "authority",
    "projects",
    "decisions_in_force",
    "open_errors",
    "validated_patterns",
    "authorization_state",
    "next_authorized_action",
    "continuity_read_order"
  ],
  "properties": {
    "schema_version": {
      "const": "2.2.0"
    },
    "document_id": {
      "const": "lab.current-state"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "active_project": {
      "type": "string"
    },
    "current_phase": {
      "type": "string"
    },
    "methodology": {
      "type": "object"
    },
    "authority": {
      "type": "object"
    },
    "projects": {
      "type": "object"
    },
    "decisions_in_force": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "open_errors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "validated_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "authorization_state": {
      "type": "object"
    },
    "next_authorized_action": {
      "type": "string"
    },
    "continuity_read_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract": {
      "type": "object"
    },
    "canonical_model": {
      "type": "object"
    },
    "verified_external_heads": {
      "type": "object"
    },
    "next_recommended_transition": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
