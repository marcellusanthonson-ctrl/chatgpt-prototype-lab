{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab.local/schemas/visual-preference-profile.schema.json",
  "title": "LAB visual preference profile",
  "type": "object",
  "required": ["schema_version", "document_id", "version", "status", "subject", "source_evidence", "scope_boundary", "dimensions", "signals", "reconciliations", "reference_provenance", "authorization_boundary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "document_id": {"pattern": "^visual-preference-profile\\.[a-z0-9-]+$"},
    "version": {"type": "string", "minLength": 1},
    "status": {"const": "DOCUMENTED_NOT_IMPLEMENTED"},
    "subject": {"type": "string", "minLength": 1},
    "source_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
    "scope_boundary": {"$ref": "#/$defs/scopeBoundary"},
    "dimensions": {"type": "object", "required": ["typography", "color", "composition", "imagery_and_render", "materiality", "controls", "information_density", "motion", "accessibility_boundaries"], "properties": {"typography": {"$ref": "#/$defs/dimension"}, "color": {"$ref": "#/$defs/dimension"}, "composition": {"$ref": "#/$defs/dimension"}, "imagery_and_render": {"$ref": "#/$defs/dimension"}, "materiality": {"$ref": "#/$defs/dimension"}, "controls": {"$ref": "#/$defs/dimension"}, "information_density": {"$ref": "#/$defs/dimension"}, "motion": {"$ref": "#/$defs/dimension"}, "accessibility_boundaries": {"$ref": "#/$defs/dimension"}}, "additionalProperties": false},
    "signals": {"type": "object", "required": ["preferred", "contextual", "insufficient", "rejected"], "properties": {"preferred": {"$ref": "#/$defs/signals"}, "contextual": {"$ref": "#/$defs/signals"}, "insufficient": {"$ref": "#/$defs/signals"}, "rejected": {"$ref": "#/$defs/signals"}}, "additionalProperties": false},
    "reconciliations": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/reconciliation"}},
    "reference_provenance": {"$ref": "#/$defs/provenance"},
    "authorization_boundary": {"$ref": "#/$defs/authorization"}
  },
  "$defs": {
    "evidence": {"type": "object", "required": ["id", "source_type", "provenance", "authority"], "properties": {"id": {"type": "string"}, "source_type": {"enum": ["USER_AUTHORIZATION", "HUMAN_REFERENCE", "HUMAN_REVIEW"]}, "provenance": {"type": "string"}, "authority": {"enum": ["CONSTRAINT_EVIDENCE", "PREFERENCE_EVIDENCE", "NOT_AUTHORIZATION"]}}, "additionalProperties": false},
    "scopeBoundary": {"type": "object", "required": ["personal_profile_not_global_governance", "project_direction_requires_selection"], "properties": {"personal_profile_not_global_governance": {"const": true}, "project_direction_requires_selection": {"const": true}}, "additionalProperties": false},
    "dimension": {"type": "object", "required": ["classification", "guidance"], "properties": {"classification": {"enum": ["FIRM", "CONTEXTUAL", "INSUFFICIENT", "REJECTED"]}, "guidance": {"type": "string", "minLength": 1}}, "additionalProperties": false},
    "signals": {"type": "array", "items": {"type": "object", "required": ["id", "statement", "evidence_id"], "properties": {"id": {"type": "string"}, "statement": {"type": "string"}, "evidence_id": {"type": "string"}}, "additionalProperties": false}},
    "reconciliation": {"type": "object", "required": ["id", "rule"], "properties": {"id": {"type": "string"}, "rule": {"type": "string"}}, "additionalProperties": false},
    "provenance": {"type": "object", "required": ["references_are_evidence_not_authorization", "copy_reference_images", "claim_reference_ownership"], "properties": {"references_are_evidence_not_authorization": {"const": true}, "copy_reference_images": {"const": "PROHIBITED"}, "claim_reference_ownership": {"const": "PROHIBITED"}}, "additionalProperties": false},
    "authorization": {"type": "object", "required": ["application_code", "html_generation", "css_generation", "javascript_generation", "runtime", "product_changes", "deployment", "release"], "properties": {"application_code": {"const": "NOT_AUTHORIZED"}, "html_generation": {"const": "NOT_AUTHORIZED"}, "css_generation": {"const": "NOT_AUTHORIZED"}, "javascript_generation": {"const": "NOT_AUTHORIZED"}, "runtime": {"const": "NOT_AUTHORIZED"}, "product_changes": {"const": "NOT_AUTHORIZED"}, "deployment": {"const": "NOT_AUTHORIZED"}, "release": {"const": "NOT_AUTHORIZED"}}, "additionalProperties": false}
  },
  "additionalProperties": false
}
