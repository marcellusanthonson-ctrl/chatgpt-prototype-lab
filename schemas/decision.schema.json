{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab.local/schemas/decision.schema.json",
  "title": "LAB decision record",
  "type": "object",
  "required": [
    "id",
    "title",
    "project",
    "status",
    "effective_date",
    "approved_by",
    "approval_evidence",
    "decision",
    "supersedes",
    "superseded_by"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^DEC-[A-Z]+-[0-9]{3}$"},
    "title": {"type": "string", "minLength": 1},
    "project": {"type": "string", "minLength": 1},
    "project_scope": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "status": {
      "enum": ["DRAFT", "PROPOSED", "UNDER_REVIEW", "APPROVED", "REJECTED", "SUPERSEDED", "WITHDRAWN"]
    },
    "effective_date": {"type": "string", "format": "date"},
    "updated_at": {"type": "string", "format": "date"},
    "approved_by": {"type": ["string", "null"]},
    "approval_evidence": {"type": ["string", "null"]},
    "evidence": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "decision": {"type": "object"},
    "supersedes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "superseded_by": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
