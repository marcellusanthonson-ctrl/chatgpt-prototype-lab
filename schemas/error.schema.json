{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab.local/schemas/error.schema.json",
  "title": "LAB error registry record",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "lifecycle_state",
    "severity",
    "project_scope",
    "canonical_path",
    "updated_at"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^ERR-[A-Z]+-[0-9]{3}$"},
    "title": {"type": "string", "minLength": 1},
    "status": {"enum": ["OPEN", "CONTAINED", "CORRECTED", "VERIFIED", "CLOSED"]},
    "lifecycle_state": {"enum": ["OPEN", "CONTAINED", "CORRECTED", "VERIFIED", "CLOSED"]},
    "severity": {"enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "project_scope": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "canonical_path": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "format": "date"}
  },
  "additionalProperties": false
}
