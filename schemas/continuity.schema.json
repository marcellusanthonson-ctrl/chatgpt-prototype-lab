{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab.local/schemas/continuity.schema.json",
  "title": "continuity",
  "type": "object",
  "required": [
    "protocol_version",
    "project_id",
    "generated_at",
    "status",
    "repositories",
    "reading_order",
    "current_state",
    "approved_decisions",
    "authorizations",
    "pending_work",
    "attachments_ref",
    "next_recommended_action",
    "prohibited_actions",
    "first_message"
  ],
  "properties": {
    "protocol_version": {
      "const": "1.0.0"
    },
    "project_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "status": {
      "enum": [
        "CURRENT",
        "STALE",
        "ARCHIVED"
      ]
    },
    "repositories": {
      "type": "array",
      "minItems": 1
    },
    "reading_order": {
      "type": "array",
      "minItems": 1
    },
    "current_state": {
      "type": "object"
    },
    "approved_decisions": {
      "type": "array"
    },
    "authorizations": {
      "type": "object"
    },
    "pending_work": {
      "type": "array"
    },
    "attachments_ref": {
      "type": "string"
    },
    "next_recommended_action": {
      "type": "object"
    },
    "prohibited_actions": {
      "type": "array"
    },
    "first_message": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
