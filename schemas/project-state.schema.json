{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab.local/schemas/project-state.schema.json",
  "title": "LAB project registry record",
  "type": "object",
  "required": ["id", "name", "status", "canonical_path", "scope", "updated_at"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "status": {
      "enum": ["active", "active_with_blocker", "active_pipeline_validated_phase_a", "known", "known_and_synced", "referenced", "paused", "archived"]
    },
    "canonical_path": {"type": "string", "minLength": 1},
    "repository": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "format": "date"}
  },
  "additionalProperties": false
}
