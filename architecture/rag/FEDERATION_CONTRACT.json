    "model_direct_commit": false,
    "model_direct_push": false,
    "steps": [
      {"order": 1, "id": "EMIT_TYPED_PROPOSAL", "gate": "Schema-valid proposal only"},
      {"order": 2, "id": "RESOLVE_CANONICAL_OWNER", "gate": "Exactly one target repository"},
      {"order": 3, "id": "MATERIALIZE_TEMPORARY_CHANGE", "gate": "No canonical mutation"},
      {"order": 4, "id": "RUN_REPOSITORY_VALIDATOR", "gate": "All repository checks pass"},
      {"order": 5, "id": "CHECK_ACTIVE_AUTHORIZATION", "gate": "Approver, HEAD, paths and actions match"},
      {"order": 6, "id": "COMMIT_CANONICAL_CHANGE", "gate": "Bounded executor only"},
      {"order": 7, "id": "REBUILD_DERIVED_NAMESPACE", "gate": "Verified canonical commit exists"}
    ]
