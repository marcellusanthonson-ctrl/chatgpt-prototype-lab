    "result_contract": {"citations_required": true, "commit_pin_required": true, "conflict_state_required": true}
  },
  "index_contract": {
    "role": "DERIVED_READ_ONLY_CACHE",
    "rules": [
      "INDEX_IS_DERIVED_READ_ONLY_CACHE",
      "REPOSITORY_IS_SOURCE_OF_TRUTH",
      "REBUILD_ON_CANONICAL_PUSH",
      "REBUILD_ONLY_AFFECTED_NAMESPACE",
      "REMOVE_STALE_CHUNKS",
      "PIN_ACTIVE_COMMIT",
      "DETERMINISTIC_CHUNK_IDENTIFIERS",
      "NO_DIRECT_MODEL_WRITES"
