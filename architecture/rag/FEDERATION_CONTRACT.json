      "PROPOSAL_TARGETS_CANONICAL_OWNER",
      "VALIDATOR_RUNS_BEFORE_COMMIT",
      "VALIDATION_FAILURE_RETURNS_TO_MODEL",
      "COMMIT_REQUIRES_ACTIVE_AUTHORIZATION",
      "NO_AUTONOMOUS_AUTHORITY",
      "INDEX_REBUILDS_ONLY_AFTER_CANONICAL_COMMIT"
