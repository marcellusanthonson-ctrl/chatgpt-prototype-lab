      {"name": "path", "type": "repository_relative_path", "source": "GIT", "mutable": false, "description": "Ruta exacta dentro del commit"},
      {"name": "document_id", "type": "stable_string", "source": "CANONICAL_DOCUMENT", "mutable": false, "description": "Identificador estable independiente del chunk"},
      {"name": "commit_sha", "type": "git_sha40", "source": "GIT", "mutable": false, "description": "Commit exacto del contenido indexado"},
      {"name": "content_sha256", "type": "sha256_hex", "source": "INDEXER_DERIVED", "mutable": false, "description": "Hash del contenido normalizado del chunk"},
