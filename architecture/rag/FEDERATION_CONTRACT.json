      {"name": "project_scope", "type": "global_or_project_id", "source": "CANONICAL_DOCUMENT", "mutable": false, "description": "Ámbito que impide contaminación entre proyectos"},
      {"name": "document_status", "type": "controlled_status", "source": "CANONICAL_DOCUMENT", "mutable": false, "description": "Estado canónico como aprobado, draft o superseded"},
