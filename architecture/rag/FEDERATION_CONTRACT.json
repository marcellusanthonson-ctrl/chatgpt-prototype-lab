      {"order": 2, "id": "SELECT_AUTHORIZED_NAMESPACES", "outcome": "Namespaces permitidos por tarea y ACL"},
      {"order": 3, "id": "VERIFY_ACTIVE_COMMITS", "outcome": "HEADs o commits aprobados y verificables"},
      {"order": 4, "id": "FILTER_BY_AUTHORITY_AND_STATUS", "outcome": "Solo propietarios, ámbitos y estados aplicables"},
      {"order": 5, "id": "RETRIEVE_WITHIN_NAMESPACE", "outcome": "Candidatos semánticos dentro de cada namespace"},
      {"order": 6, "id": "RANK_AUTHORITY_THEN_RELEVANCE", "outcome": "Autoridad preservada y similitud usada solo entre candidatos válidos"},
      {"order": 7, "id": "DETECT_CROSS_SOURCE_CONFLICTS", "outcome": "Estado explícito de compatibilidad o conflicto"},
      {"order": 8, "id": "RETURN_CITED_CONTEXT", "outcome": "Contexto con repository, path, commit y document_id"}
