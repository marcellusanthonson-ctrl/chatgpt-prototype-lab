    "trigger": "VERIFIED_CANONICAL_PUSH",
    "affected_namespace_only": true,
    "stale_removal": "DELETE_CHUNKS_ABSENT_FROM_NEW_CANONICAL_MANIFEST",
    "commit_pin": "EXACT_SOURCE_COMMIT_SHA"
  },
  "conflict_contract": {
    "automatic_merge": false,
    "states": ["NONE", "SUSPECTED", "CONFIRMED", "RESOLUTION_REQUIRED", "RESOLVED"],
    "on_confirmed_conflict": "STOP_CONCLUSION_AND_RETURN_SOURCES",
    "resolution_authority": "CANONICAL_OWNER_WITH_EXPLICIT_APPROVAL",
    "resolution_evidence": "NEW_CANONICAL_COMMIT"
  },
  "write_boundary": {
