    ],
    "chunk_id_formula": "sha256(repository + newline + path + newline + document_id + newline + ordinal + newline + content_sha256)"
  },
  "authority_rules": [
    "AUTHORITY_BEFORE_SEMANTIC_SIMILARITY",
